<clickhouse>
    <!-- Single-node cluster required by Langfuse v3 ReplicatedMergeTree migrations -->
    <remote_servers replace="true">
        <default>
            <shard>
                <internal_replication>false</internal_replication>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </default>
    </remote_servers>

    <!-- ClickHouse Keeper (built-in ZooKeeper replacement for single-node) -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>clickhouse</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- Point to the Keeper instance above -->
    <zookeeper>
        <node>
            <host>clickhouse</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Macros for ReplicatedMergeTree table paths -->
    <macros>
        <shard>01</shard>
        <replica>01</replica>
    </macros>
</clickhouse>
