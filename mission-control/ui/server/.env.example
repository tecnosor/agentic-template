# Mission Control — Server Environment Variables
# Copy this file to .env and fill in your values.

# Port for the Express server (default: 3099)
PORT=3099

# Absolute path to your workspace root (the folder containing all your repos).
# Default: auto-resolved as 4 levels up from mission-control/ui/server/src/.
# Override this if your directory structure doesn't match the template layout.
# Example: WORKSPACE_ROOT=/home/user/projects/my-workspace
WORKSPACE_ROOT=

# Comma-separated list of repo directory names to watch (optional).
# Default: auto-discovered (any folder under WORKSPACE_ROOT that has kanban/tasks/).
# Override to limit or force specific repos.
# Example: REPOS=my-api,my-frontend,mission-control
REPOS=

# GitHub personal access token — needed for PR/issue integrations
# Scopes required: repo (read), pull_requests (read)
GITHUB_TOKEN=

# GitHub organization name — used to construct GitHub URLs
# Leave empty if your repos are under your personal account
GITHUB_ORG=
