# Mission Control — Server Environment Variables
# Copy this file to .env and fill in your values.

# Port for the Express server (default: 3099)
PORT=3099

# GitHub personal access token — needed for PR/issue integrations
# Scopes required: repo (read), pull_requests (read)
GITHUB_TOKEN=

# GitHub organization name — used to construct GitHub URLs
# Leave empty if your repos are under your personal account
GITHUB_ORG=
