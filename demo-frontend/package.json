    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
